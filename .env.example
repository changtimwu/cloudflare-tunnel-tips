CLOUDFLARE_DOMAIN=wormhole.work
CLOUDFLARE_API_TOKEN=your_token_here
# Required for get-tunnel-token.sh — your tunnel-scoped token can't list accounts,
# so the account ID must be supplied here. Find it in any existing
# ~/.cloudflared/<tunnel-id>.json under the "AccountTag" field.
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
